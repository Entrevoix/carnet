{
  "expo": {
    "name": "Carnet",
    "slug": "carnet",
    "scheme": "carnet",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "us.beary.carnet",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Carnet uses speech recognition to transcribe your voice notes into journal entries.",
        "NSMicrophoneUsageDescription": "Carnet uses the microphone to capture voice notes.",
        "NSCameraUsageDescription": "Carnet uses the camera to capture business cards for the contact mode."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "adjustResize",
      "package": "us.beary.carnet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5E63FF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_SPECIAL_USE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Carnet uses the camera to capture business cards for contacts."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "androidSpeechServicePackages": [
            "com.google.android.as",
            "com.google.android.tts"
          ]
        }
      ],
      "./plugins/withSpeechRecognitionQueries",
      "./plugins/withAppShortcuts",
      "./plugins/withCaptureNotification",
      "./plugins/withCaptureWidget",
      "./plugins/withAudioDecoder",
      [
        "expo-share-intent",
        {
          "androidIntentFilters": ["text/*", "image/*", "audio/*", "*/*"]
        }
      ]
    ]
  }
}
